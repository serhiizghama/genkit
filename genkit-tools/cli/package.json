{
  "name": "genkit-cli",
  "version": "1.33.0",
  "description": "CLI for interacting with the Google Genkit AI framework",
  "license": "Apache-2.0",
  "keywords": [
    "genkit",
    "ai",
    "genai",
    "generative-ai"
  ],
  "author": "genkit",
  "bin": {
    "genkit": "dist/bin/genkit.js"
  },
  "files": [
    "dist/"
  ],
  "main": "dist/index.js",
  "scripts": {
    "build": "pnpm genversion && tsc",
    "build:watch": "tsc --watch",
    "compile:bun": "bun build src/bin/genkit.ts --compile --outfile dist/bin/genkit --minify",
    "test": "jest --verbose",
    "genversion": "genversion -esf --property name,version src/utils/version.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/genkit-ai/genkit.git",
    "directory": "genkit-tools/cli"
  },
  "dependencies": {
    "@genkit-ai/telemetry-server": "workspace:*",
    "@genkit-ai/tools-common": "workspace:*",
    "@inquirer/prompts": "^8.4.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.16.0",
    "colorette": "^2.0.20",
    "commander": "^14.0.3",
    "extract-zip": "^2.0.1",
    "get-port": "7.2.0",
    "open": "^11.0.0",
    "ora": "^9.4.0",
    "semver": "^7.8.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.2",
    "@types/semver": "^7.7.0",
    "bun-types": "^1.3.13",
    "genversion": "^3.2.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
